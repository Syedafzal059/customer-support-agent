# Copy to `.env` in this directory (never commit `.env`).
# Loaded by app.core.config via python-dotenv.

# Required for POST /chat on cache miss (intent + RAG/ticket generation)
# OPENAI_API_KEY=

# Optional
# OPENAI_BASE_URL=
# OPENAI_INTENT_MODEL=gpt-4o-mini
# OPENAI_RAG_QA_MODEL=gpt-4o-mini
# OPENAI_TICKET_SUMMARY_MODEL=gpt-4o-mini
# EMBEDDING_MODEL_ID=BAAI/bge-base-en-v1.5
# KNOWLEDGE_BASE_DIR=data/knowledge_base
# RAG_TOP_K=3
# RAG_CHUNK_SIZE_TOKENS=400
# RAG_CHUNK_OVERLAP_TOKENS=50
# CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# LOG_LEVEL=INFO
# REDIS_BACKEND=memory
# REDIS_URL=redis://localhost:6379/0
